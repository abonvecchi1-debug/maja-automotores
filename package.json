{
  "name": "maja-automotores",
  "version": "1.0.12",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev:client": "vite",
    "seed:admin": "node server/seed-admin.js",
    "dev:server": "node server/index.js",
    "dev": "concurrently --kill-others-on-fail \"npm run dev:server\" \"npm run dev:client\"",
    "build": "tsc && vite build",
    "start": "NODE_ENV=production node server/index.js",
    "preview": "vite preview",
    "electron:pack": "npm run build && npx @electron/rebuild -f -w better-sqlite3 && electron-builder --win"
  },
  "dependencies": {
    "electron-updater": "^6.3.0",
    "groq-sdk": "^0.9.0",
    "jspdf": "^2.5.1",
    "jspdf-autotable": "^3.8.0",
    "xlsx": "^0.18.5",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.9.0",
    "clsx": "^2.1.0",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "date-fns": "^3.3.1",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.323.0",
    "multer": "^2.1.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.0",
    "recharts": "^2.10.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.0",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "vite": "^5.1.0"
  }
}
